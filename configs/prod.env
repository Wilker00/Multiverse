# Production Environment Configuration
# Maximum robustness, performance, observability
# Usage: ln -s configs/prod.env .env (or copy to .env)

# ============================================================================
# REQUIRED FOR DOCKER
# ============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_PROD_PASSWORD}  # REQUIRED: Set via secrets management

# ============================================================================
# MEMORY SYSTEM - High Performance
# ============================================================================
MULTIVERSE_MEMORY_LOCK_TIMEOUT=60                  # Longer timeout for safety
MULTIVERSE_MEMORY_DELTA_MERGE_THRESHOLD=1000
MULTIVERSE_MEMORY_QUERY_CACHE_SIZE=50000           # Large cache for performance
MULTIVERSE_MEMORY_QUERY_CACHE_TTL_MS=300000        # 5 minute TTL
MULTIVERSE_SIM_USE_ANN=1                           # FAISS enabled
MULTIVERSE_SIM_ANN_CANDIDATE_COUNT=200             # Higher accuracy
MULTIVERSE_SIM_CACHE_LIMIT=500000                  # Large cache for scale
MULTIVERSE_SIM_ANN_DRIFT_CHECK_EVERY=10000
MULTIVERSE_SIM_ANN_MAX_DRIFT=0.03                  # Stricter drift tolerance

# ============================================================================
# ROLLOUT CONFIGURATION - Optimized for Quality
# ============================================================================
MULTIVERSE_ROLLOUT_RETRIEVAL_INTERVAL=10
MULTIVERSE_ROLLOUT_QUERY_BUDGET=10                 # More memory access for better decisions
MULTIVERSE_ROLLOUT_MIN_INTERVAL=2

# ============================================================================
# PARALLEL EXECUTION - High Parallelism
# ============================================================================
MULTIVERSE_PARALLEL_NUM_WORKERS=32                 # High worker count for throughput
MULTIVERSE_PARALLEL_MAX_TIMEOUT=7200               # 2 hour timeout

# ============================================================================
# MCTS - Deep Search for Critical Decisions
# ============================================================================
MULTIVERSE_MCTS_NUM_SIMULATIONS=128                # More simulations
MULTIVERSE_MCTS_MAX_DEPTH=16                       # Deeper search
MULTIVERSE_MCTS_C_PUCT=1.4
MULTIVERSE_MCTS_TRANSPOSITION_MAX_ENTRIES=100000   # Large transposition table

# ============================================================================
# CURRICULUM - Enabled with Conservative Settings
# ============================================================================
MULTIVERSE_CURRICULUM_ENABLED=1
MULTIVERSE_CURRICULUM_PLATEAU_WINDOW=10            # Longer window for stability
MULTIVERSE_CURRICULUM_STEP_SIZE=0.03               # Gradual adjustments
MULTIVERSE_CURRICULUM_COLLAPSE_THRESHOLD=0.15      # Stricter collapse detection
MULTIVERSE_CURRICULUM_MAX_NOISE=0.35
MULTIVERSE_CURRICULUM_MAX_PARTIAL_OBS=0.75
MULTIVERSE_CURRICULUM_MAX_DISTRACTORS=6

# ============================================================================
# SAFE EXECUTOR - Maximum Safety
# ============================================================================
# Configure via SafeExecutorConfig with:
# - danger_threshold=0.88 (stricter than default 0.90)
# - min_action_confidence=0.10 (stricter than default 0.08)
# - adaptive_veto_enabled=True
# - fallback_horizon_steps=10
# - checkpoint_interval=5
# - max_rewinds_per_episode=10
# - planner_enabled=True, planner_max_expansions=10000
# - planning_budget_per_episode=10
# - mcts_enabled=True, mcts_num_simulations=128, mcts_max_depth=6
# - danger_map_path="models/production_danger_map.json"
# - failure_signature_path="models/production_failure_signatures.json"

# ============================================================================
# PRODUCTION SETTINGS
# ============================================================================
DEBUG=0                                            # Disable debug mode
LOG_LEVEL=INFO
LOG_FORMAT=json                                    # Structured logging for aggregation

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# REDIS_HOST=prod-redis.internal
# REDIS_PORT=6379
# REDIS_PASSWORD=${REDIS_PROD_PASSWORD}
# CHROMA_HOST=prod-chroma.internal
# CHROMA_PORT=8000
# PROMETHEUS_HOST=prod-prometheus.internal
# PROMETHEUS_PORT=9090

# ============================================================================
# OBSERVABILITY
# ============================================================================
# Enable metrics export, telemetry, etc.
# MULTIVERSE_METRICS_ENABLED=1
# MULTIVERSE_TELEMETRY_ENDPOINT=https://telemetry.example.com

# ============================================================================
# DATA PERSISTENCE
# ============================================================================
# Production paths for shared storage
# MULTIVERSE_MEMORY_ROOT=/data/central_memory
# MULTIVERSE_RUNS_ROOT=/data/runs
# MULTIVERSE_MODELS_ROOT=/data/models

# ============================================================================
# SECURITY
# ============================================================================
# TLS certificates, API keys, etc.
# MULTIVERSE_TLS_CERT_PATH=/etc/ssl/certs/multiverse.crt
# MULTIVERSE_TLS_KEY_PATH=/etc/ssl/private/multiverse.key

# ============================================================================
# NOTES
# ============================================================================
# Production priorities:
# - Maximum robustness and safety
# - High throughput (32 workers)
# - Large caches for performance
# - Conservative curriculum adjustments
# - Structured logging (JSON)
# - External service integration
# - Secrets via environment/vault (not in this file)
#
# CRITICAL: Set all *_PASSWORD and secret variables via:
# - Kubernetes secrets
# - AWS Secrets Manager
# - HashiCorp Vault
# - Environment-specific .env.local (gitignored)
