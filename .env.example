# Multiverse Configuration
# Copy this file to .env and customize for your environment
# Usage: cp .env.example .env

# ============================================================================
# REQUIRED FOR DOCKER DEPLOYMENT
# ============================================================================

# Grafana admin credentials (required by docker-compose.scale.yml)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_secure_password_here

# ============================================================================
# MEMORY SYSTEM CONFIGURATION
# ============================================================================

# Lock timeout in seconds for multiprocess coordination
# Default: 30 seconds
# MULTIVERSE_MEMORY_LOCK_TIMEOUT=30

# Delta merge threshold - number of rows before auto-merging cache deltas
# Default: 1000 rows
# MULTIVERSE_MEMORY_DELTA_MERGE_THRESHOLD=1000

# Query result cache size (number of cached queries)
# Default: 10000 entries
# MULTIVERSE_MEMORY_QUERY_CACHE_SIZE=10000

# Query cache TTL in milliseconds
# Default: 60000 (1 minute)
# MULTIVERSE_MEMORY_QUERY_CACHE_TTL_MS=60000

# Maximum number of similarity cache files to keep in memory
# Default: 2
# MULTIVERSE_SIM_CACHE_MAX_FILES=2

# Enable ANN (Approximate Nearest Neighbor) for similarity search
# Options: 0 (disabled), 1 (enabled)
# Default: 1 (enabled)
# MULTIVERSE_SIM_USE_ANN=1

# ANN candidate expansion factor
# Higher values = more accurate but slower
# Default: 64
# MULTIVERSE_SIM_ANN_FACTOR=64

# How often to check ANN drift (every N queries)
# Default: 250
# MULTIVERSE_SIM_ANN_DRIFT_CHECK_EVERY=250

# Maximum allowed drift for ANN vs exact search
# Default: 0.03 (3%)
# MULTIVERSE_SIM_ANN_MAX_DRIFT=0.03

# Universal observation dimension for cross-verse embedding
# Default: 64
# MULTIVERSE_UNIVERSAL_OBS_DIM=64

# ============================================================================
# SEMANTIC BRIDGE (TRANSFER LEARNING)
# ============================================================================

# Path to pre-trained semantic bridge model
# Leave empty to use default or train from scratch
# MULTIVERSE_BRIDGE_MODEL_PATH=

# ============================================================================
# SAFETY EXECUTOR
# ============================================================================

# Enable verbose logging for SafeExecutor
# Options: 0 (disabled), 1 (enabled)
# Default: 0
# MULTIVERSE_SAFE_EXECUTOR_VERBOSE=0

# ============================================================================
# STREAMING PIPELINE
# ============================================================================

# Maximum queue size for local event bus
# Default: 20000
# MULTIVERSE_LOCAL_BUS_MAX_QUEUE=20000

# Overflow behavior when queue is full
# Options: drop_oldest, drop_newest, block
# Default: drop_oldest
# MULTIVERSE_LOCAL_BUS_OVERFLOW=drop_oldest

# ============================================================================
# PATHS AND DIRECTORIES
# ============================================================================

# Root directory for training run artifacts
# Default: ./runs
# MULTIVERSE_RUNS_ROOT=./runs

# Root directory for central memory storage
# Default: ./central_memory
# MULTIVERSE_MEMORY_ROOT=./central_memory

# ============================================================================
# ROLLOUT CONFIGURATION
# ============================================================================

# Steps between memory retrievals during rollout
# Default: 10
# Lower values = more frequent memory queries (slower but more informed)
# MULTIVERSE_ROLLOUT_RETRIEVAL_INTERVAL=10

# Maximum memory queries per episode (on-demand memory)
# Default: 8
# Higher values allow more memory access but may slow down rollouts
# MULTIVERSE_ROLLOUT_QUERY_BUDGET=8

# Minimum steps between consecutive memory queries
# Default: 2
# Prevents excessive querying on every step
# MULTIVERSE_ROLLOUT_MIN_INTERVAL=2

# ============================================================================
# PARALLEL EXECUTION CONFIGURATION
# ============================================================================

# Number of parallel worker processes for rollouts
# Default: 4
# Recommendation: Set to number of CPU cores - 1, or 8 for production
# MULTIVERSE_PARALLEL_NUM_WORKERS=4

# Maximum timeout for worker processes (seconds)
# Default: 3600 (1 hour)
# Workers running longer than this will be terminated
# MULTIVERSE_PARALLEL_MAX_TIMEOUT=3600

# ============================================================================
# MCTS (MONTE CARLO TREE SEARCH) CONFIGURATION
# ============================================================================

# Number of MCTS simulations per search
# Default: 96
# Higher values = better decisions but slower
# MULTIVERSE_MCTS_NUM_SIMULATIONS=96

# Maximum MCTS simulation depth
# Default: 12
# MULTIVERSE_MCTS_MAX_DEPTH=12

# MCTS exploration constant (PUCT)
# Default: 1.4
# Higher values = more exploration vs exploitation
# MULTIVERSE_MCTS_C_PUCT=1.4

# Transposition table maximum entries (deduplicates game states)
# Default: 20000
# Higher values use more memory but improve MCTS performance
# MULTIVERSE_MCTS_TRANSPOSITION_MAX_ENTRIES=20000

# ============================================================================
# CURRICULUM LEARNING CONFIGURATION
# ============================================================================

# Enable adaptive curriculum learning
# Default: 1 (enabled)
# MULTIVERSE_CURRICULUM_ENABLED=1

# Number of episodes to detect performance plateau
# Default: 5
# MULTIVERSE_CURRICULUM_PLATEAU_WINDOW=5

# Difficulty adjustment step size
# Default: 0.05
# Lower values = more gradual difficulty changes
# MULTIVERSE_CURRICULUM_STEP_SIZE=0.05

# Success rate below which agent is considered "collapsed"
# Default: 0.20 (20%)
# Triggers difficulty reduction to help agent recover
# MULTIVERSE_CURRICULUM_COLLAPSE_THRESHOLD=0.20

# Maximum action noise for curriculum difficulty
# Default: 0.35
# MULTIVERSE_CURRICULUM_MAX_NOISE=0.35

# Maximum partial observability (0.0 = full obs, 1.0 = fully blind)
# Default: 0.75
# MULTIVERSE_CURRICULUM_MAX_PARTIAL_OBS=0.75

# Maximum number of distractor objects
# Default: 6
# MULTIVERSE_CURRICULUM_MAX_DISTRACTORS=6

# ============================================================================
# LOGGING
# ============================================================================

# Log level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# Log format
# Options: simple, detailed, json
# Default: simple
# LOG_FORMAT=simple

# ============================================================================
# EXTERNAL SERVICES (for docker-compose.scale.yml)
# ============================================================================

# Redis connection
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Kafka connection
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ChromaDB connection
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# Prometheus connection
# PROMETHEUS_HOST=localhost
# PROMETHEUS_PORT=9090

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Enable debug mode (more verbose logging, no multiprocessing)
# DEBUG=0

# Disable GPU even if available (for testing CPU-only code)
# CUDA_VISIBLE_DEVICES=-1

# Set random seed for reproducibility
# MULTIVERSE_SEED=42

# ============================================================================
# NOTES
# ============================================================================
#
# - Most settings have sensible defaults and don't need to be set
# - Only GF_SECURITY_ADMIN_PASSWORD is REQUIRED for Docker deployment
# - Uncomment (remove #) and modify values as needed
# - Boolean values: 0/1, false/true, off/on are all accepted
# - Paths can be absolute or relative to project root
#
