# Development Environment Configuration
# Fast iteration, minimal safety overhead, local storage
# Usage: ln -s configs/dev.env .env (or copy to .env)

# ============================================================================
# REQUIRED FOR DOCKER (if using docker-compose.scale.yml)
# ============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=dev_password_123

# ============================================================================
# MEMORY SYSTEM - Development Settings
# ============================================================================
MULTIVERSE_MEMORY_LOCK_TIMEOUT=30
MULTIVERSE_MEMORY_DELTA_MERGE_THRESHOLD=500        # Smaller = more frequent merges
MULTIVERSE_MEMORY_QUERY_CACHE_SIZE=1000            # Small cache for faster iteration
MULTIVERSE_MEMORY_QUERY_CACHE_TTL_MS=30000         # 30 second TTL
MULTIVERSE_SIM_USE_ANN=0                           # Disable FAISS for small datasets
MULTIVERSE_SIM_CACHE_LIMIT=10000                   # Small cache limit

# ============================================================================
# ROLLOUT CONFIGURATION - Fast Feedback
# ============================================================================
MULTIVERSE_ROLLOUT_RETRIEVAL_INTERVAL=20           # Less frequent memory queries
MULTIVERSE_ROLLOUT_QUERY_BUDGET=3                  # Limit memory access for speed
MULTIVERSE_ROLLOUT_MIN_INTERVAL=5                  # Allow fewer queries

# ============================================================================
# PARALLEL EXECUTION - Low Parallelism
# ============================================================================
MULTIVERSE_PARALLEL_NUM_WORKERS=2                  # Minimal workers for debugging
MULTIVERSE_PARALLEL_MAX_TIMEOUT=1800               # 30 min timeout

# ============================================================================
# MCTS - Fast Search
# ============================================================================
MULTIVERSE_MCTS_NUM_SIMULATIONS=32                 # Reduced for speed
MULTIVERSE_MCTS_MAX_DEPTH=6                        # Shallow search
MULTIVERSE_MCTS_C_PUCT=1.2
MULTIVERSE_MCTS_TRANSPOSITION_MAX_ENTRIES=5000     # Small transposition table

# ============================================================================
# CURRICULUM - Disabled for Manual Control
# ============================================================================
MULTIVERSE_CURRICULUM_ENABLED=0                    # Manual difficulty tuning
MULTIVERSE_CURRICULUM_PLATEAU_WINDOW=3
MULTIVERSE_CURRICULUM_STEP_SIZE=0.10               # Aggressive when enabled
MULTIVERSE_CURRICULUM_COLLAPSE_THRESHOLD=0.30

# ============================================================================
# SAFE EXECUTOR - Relaxed Safety
# ============================================================================
# Note: SafeExecutor params are best configured via SafeExecutorConfig objects
# But can add environment variables if needed in future

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
DEBUG=0                                            # Set to 1 for verbose logging
MULTIVERSE_SEED=42                                 # Fixed seed for reproducibility

# ============================================================================
# NOTES
# ============================================================================
# Development priorities:
# - Fast iteration (reduced workers, simulations, cache sizes)
# - Reproducibility (fixed seed)
# - Minimal safety overhead
# - Local-only storage
# - Easy debugging (small parallel configs, disabled ANN)
