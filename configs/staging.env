# Staging Environment Configuration
# Realistic evaluation, full safety stack, shared memory
# Usage: ln -s configs/staging.env .env (or copy to .env)

# ============================================================================
# REQUIRED FOR DOCKER
# ============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_STAGING_PASSWORD}  # Set via external secret

# ============================================================================
# MEMORY SYSTEM - Production-Like Settings
# ============================================================================
MULTIVERSE_MEMORY_LOCK_TIMEOUT=45
MULTIVERSE_MEMORY_DELTA_MERGE_THRESHOLD=1000       # Standard merge threshold
MULTIVERSE_MEMORY_QUERY_CACHE_SIZE=10000           # Standard cache size
MULTIVERSE_MEMORY_QUERY_CACHE_TTL_MS=60000         # 1 minute TTL
MULTIVERSE_SIM_USE_ANN=1                           # Enable FAISS for performance
MULTIVERSE_SIM_ANN_CANDIDATE_COUNT=100
MULTIVERSE_SIM_CACHE_LIMIT=150000
MULTIVERSE_SIM_ANN_DRIFT_CHECK_EVERY=10000
MULTIVERSE_SIM_ANN_MAX_DRIFT=0.05

# ============================================================================
# ROLLOUT CONFIGURATION - Balanced Settings
# ============================================================================
MULTIVERSE_ROLLOUT_RETRIEVAL_INTERVAL=10           # Standard retrieval
MULTIVERSE_ROLLOUT_QUERY_BUDGET=8                  # Standard budget
MULTIVERSE_ROLLOUT_MIN_INTERVAL=2

# ============================================================================
# PARALLEL EXECUTION - Moderate Parallelism
# ============================================================================
MULTIVERSE_PARALLEL_NUM_WORKERS=8                  # Moderate worker count
MULTIVERSE_PARALLEL_MAX_TIMEOUT=3600               # 1 hour timeout

# ============================================================================
# MCTS - Full Search
# ============================================================================
MULTIVERSE_MCTS_NUM_SIMULATIONS=96                 # Standard MCTS
MULTIVERSE_MCTS_MAX_DEPTH=12
MULTIVERSE_MCTS_C_PUCT=1.4
MULTIVERSE_MCTS_TRANSPOSITION_MAX_ENTRIES=20000

# ============================================================================
# CURRICULUM - Enabled with Standard Settings
# ============================================================================
MULTIVERSE_CURRICULUM_ENABLED=1
MULTIVERSE_CURRICULUM_PLATEAU_WINDOW=5
MULTIVERSE_CURRICULUM_STEP_SIZE=0.05               # Gradual adjustments
MULTIVERSE_CURRICULUM_COLLAPSE_THRESHOLD=0.20
MULTIVERSE_CURRICULUM_MAX_NOISE=0.35
MULTIVERSE_CURRICULUM_MAX_PARTIAL_OBS=0.75
MULTIVERSE_CURRICULUM_MAX_DISTRACTORS=6

# ============================================================================
# SAFE EXECUTOR - Full Safety Stack
# ============================================================================
# Configure via SafeExecutorConfig with:
# - danger_threshold=0.90
# - min_action_confidence=0.08
# - planner_enabled=True, planner_max_expansions=5000
# - mcts_enabled=True, mcts_num_simulations=96

# ============================================================================
# STAGING SETTINGS
# ============================================================================
DEBUG=0
# MULTIVERSE_SEED not set - allow randomness for diverse evaluation

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# REDIS_HOST=staging-redis.internal
# REDIS_PORT=6379
# CHROMA_HOST=staging-chroma.internal
# CHROMA_PORT=8000

# ============================================================================
# NOTES
# ============================================================================
# Staging priorities:
# - Production-like configuration
# - Full safety features enabled
# - Shared memory across experiments
# - Moderate parallelism for testing scale
# - Realistic evaluation scenarios
